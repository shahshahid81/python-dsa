   "source": [
    "def fibonnaci(n: int) -> int:\n",
    "    if n <= 1:\n",
    "        return 1\n",
    "    return fibonnaci(n - 1) + fibonnaci(n - 2)\n",
    "\n",
    "\n",
    "print(fibonnaci(1))\n",
    "print(fibonnaci(5))\n"
   ]
  }
