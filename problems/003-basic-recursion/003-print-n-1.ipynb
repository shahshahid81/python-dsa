    "def print_till_1(n: int) -> None:\n",
    "    if n <= 0:\n",
    "        return\n",
    "    print(n)\n",
    "    print_till_1(n - 1)\n",
    "\n",
    "\n",
    "print_till_1(10)\n",
    "print_till_1(5)\n"
   ]
