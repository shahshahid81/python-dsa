   "source": [
    "def print_n_times(name: str, times: int) -> None:\n",
    "    if times <= 0:\n",
    "        return\n",
    "    print(name)\n",
    "    print_n_times(name, times - 1)\n",
    "\n",
    "\n",
    "print_n_times(\"John\", 5)\n",
    "print_n_times(\"Mary\", 3)\n"
   ]
  }
 ],
